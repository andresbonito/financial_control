# ============================================================
# Variáveis de ambiente — copie para .env e preencha os valores
# NUNCA commite o arquivo .env com valores reais
# ============================================================

# --- Supabase (frontend) ---
VITE_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Supabase (serverless API — api/analyze.ts) ---
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# --- Anthropic (configure no painel do Vercel, não no .env local) ---
# Obtenha em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# --- Modelo Claude (opcional) ---
# Padrão: claude-sonnet-4-20250514
CLAUDE_MODEL=claude-sonnet-4-20250514

# --- CORS (domínio do seu frontend em produção) ---
# Exemplo: https://meuapp.vercel.app
ALLOWED_ORIGIN=https://meuapp.vercel.app
